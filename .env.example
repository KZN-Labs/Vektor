# Copy to .env and fill in your key
# .env is gitignored and will never be committed

# --- Option 1: Groq (free, recommended) ---
# Get key at console.groq.com → API Keys
# GROQ_API_KEY=gsk_...

# --- Option 2: Anthropic (best quality) ---
# ANTHROPIC_API_KEY=sk-ant-api03-...

# --- Option 3: Gemini (must use aistudio.google.com key) ---
# GEMINI_API_KEY=AIza...

# Sui private key for on-chain execution (optional)
# SUI_PRIVATE_KEY=suiprivkey1...
