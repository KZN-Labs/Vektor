{
  "name": "vektor-sui",
  "version": "0.1.0",
  "description": "Intent engine for Sui — parse, guard, compile, execute.",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "contracts"
  ],
  "scripts": {
    "build": "tsup",
    "dev:server": "tsx src/server.ts",
    "dev:ui": "vite",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:ui\"",
    "test": "tsx tests/integration.test.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.55.0",
    "@mysten/dapp-kit": "^1.0.6",
    "@mysten/sui": "^2.17.0",
    "@pythnetwork/price-service-client": "^1.9.0",
    "@tanstack/react-query": "^5.100.14",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^5.0.1",
    "navi-sdk": "^1.7.3",
    "node-cron": "^4.2.1",
    "routex-sui": "^1.0.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^25.9.1",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "autoprefixer": "^10",
    "concurrently": "^9.0.0",
    "postcss": "^8",
    "react": "^18",
    "react-dom": "^18",
    "tailwindcss": "^3",
    "tsup": "^8.5.1",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vite": "^6.0.0"
  },
  "keywords": [
    "sui",
    "defi",
    "intent",
    "routing",
    "zklogin",
    "ptb",
    "aggregator"
  ],
  "license": "MIT"
}
