{
  "name": "vektor-sui",
  "version": "0.1.0",
  "description": "Intent engine for Sui. Parse, guard, compile, and execute swap intents with on-chain logging and zkLogin auth.",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "contracts"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "tsx tests/integration.test.ts"
  },
  "keywords": [
    "sui",
    "defi",
    "intent",
    "routing",
    "zklogin",
    "ptb",
    "aggregator"
  ],
  "license": "MIT",
  "dependencies": {
    "routex-sui": "^1.0.0",
    "@mysten/sui": "^2.17.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/uuid": "^10.0.0",
    "tsup": "^8.5.1",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3"
  }
}
